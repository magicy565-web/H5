# LLM (Dashscope / Qwen)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Apify (optional)
APIFY_API_TOKEN=your-apify-api-token-here

# WeCom Application Message Push
WECOM_CORP_ID=your-wecom-corp-id-here
WECOM_AGENT_ID=1000002
WECOM_SECRET=your-wecom-secret-here

# WeCom Group Bot Webhook (optional)
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key-here

# Server Chan (optional)
SERVERCHAN_KEY=your-serverchan-key-here

# Google Custom Search (optional)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CSE_ID=your-google-cse-id-here
